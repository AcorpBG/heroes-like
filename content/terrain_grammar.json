    "selection_model": "homm3_table_driven_bridge_base_lookup",
    "edge_model": "bridge_or_shoreline_atlas_frame_lookup",
    "corner_model": "diagonal_context_in_atlas_lookup",
    "cardinal_edges": true,
    "corner_hints": true,
    "bridge_base_model": "dirt_or_sand_bridge_base",
    "water_model": "shoreline_specific_lookup",
    "receiver_rule": "current_tile_selects_family_atlas_frame_from_neighbor_mask",
    "same_group_policy": "suppress_same_homm3_family_edges",
    "unsupported_policy": "explicit_grammar_fallback",
    "fallback_edge_color": "#504a34"
  },
